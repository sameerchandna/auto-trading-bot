{
  "version": 1,
  "note": "Checklist for ReadinessAgent. Each check has an evaluator name registered in agents/readiness_agent.py:CHECK_EVALUATORS. 'manual' fields let the user override flags that can't be auto-verified.",
  "manual": {
    "manual_review_done": false,
    "capital_signoff": false
  },
  "demo": [
    {
      "id": "DM-01",
      "label": "Backtest profit factor >= 1.3",
      "evaluator": "backtest_pf_min",
      "params": {"min": 1.3}
    },
    {
      "id": "DM-02",
      "label": "Backtest win rate >= 40%",
      "evaluator": "backtest_wr_min",
      "params": {"min": 0.40}
    },
    {
      "id": "DM-03",
      "label": "Backtest max drawdown <= 20%",
      "evaluator": "backtest_dd_max",
      "params": {"max": 0.20}
    },
    {
      "id": "DM-04",
      "label": "At least 200 backtest trades",
      "evaluator": "backtest_trades_min",
      "params": {"min": 200}
    },
    {
      "id": "DM-05",
      "label": "Currency conversion implemented (risk_manager uses to_gbp)",
      "evaluator": "code_contains",
      "params": {"file": "agents/risk_manager.py", "needle": "to_gbp"}
    },
    {
      "id": "DM-06",
      "label": "Daily loss limit force-closes positions",
      "evaluator": "code_contains",
      "params": {"file": "agents/risk_manager.py", "needle": "daily_limit_breached"}
    },
    {
      "id": "DM-07",
      "label": "Bulk upsert implemented (no N+1 in save_candles)",
      "evaluator": "code_contains",
      "params": {"file": "data/ingestion.py", "needle": "prefix_with(\"OR REPLACE\")"}
    },
    {
      "id": "DM-08",
      "label": "Live P&L within 25% of backtest expectancy",
      "evaluator": "live_vs_backtest_expectancy",
      "params": {"tolerance_pct": 0.25, "min_live_trades": 20}
    }
  ],
  "live": [
    {
      "id": "LV-01",
      "label": "All demo checks passing",
      "evaluator": "all_demo_pass",
      "params": {}
    },
    {
      "id": "LV-02",
      "label": "30+ days of demo trading",
      "evaluator": "demo_days_min",
      "params": {"min": 30}
    },
    {
      "id": "LV-03",
      "label": "Demo period positive expectancy",
      "evaluator": "demo_expectancy_positive",
      "params": {}
    },
    {
      "id": "LV-04",
      "label": "Demo drawdown < 15%",
      "evaluator": "demo_dd_max",
      "params": {"max": 0.15}
    },
    {
      "id": "LV-05",
      "label": "Manual review of 20+ demo trades",
      "evaluator": "manual_flag",
      "params": {"flag": "manual_review_done"}
    },
    {
      "id": "LV-06",
      "label": "Capital at risk signed off",
      "evaluator": "manual_flag",
      "params": {"flag": "capital_signoff"}
    }
  ]
}
